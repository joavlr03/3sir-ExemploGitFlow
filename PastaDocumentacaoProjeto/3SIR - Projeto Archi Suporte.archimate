    <element xsi:type="archimate:Principle" name="Entre os indicadores de desempenho é obrigatório a medição do ciclo de atendimento do tempo de ciclo de atendimento do registro à solução do chamado " id="id-702d8b66501e4aaa98e7f0abac9d3863"/>
    <element xsi:type="archimate:Principle" name="Coletar feedback de todos os clientes que abriram chamados técnicos" id="id-bfdc7d10a76748c889393dda309eb72a"/>
    <element xsi:type="archimate:Principle" name="Todo chamado técnico deve ser registrado em um sistema, permitindo a recuperaçãoda informação e acompanhamento do atendimento " id="id-fc310f049a5d460f8c7431f5df39b48c"/>
